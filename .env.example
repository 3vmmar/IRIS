# Environment variables — copy to .env and fill in all values
# Keys with no value are optional or have safe defaults.

ANTHROPIC_API_KEY=sk-ant-...   # Required — get from console.anthropic.com
VLM_MODEL=claude-haiku-4-5     # claude-haiku-4-5 (fast) | claude-sonnet-4-6 (deep)

CAMERA_INDEX=0
FRAME_SKIP=3                   # Run YOLO inference every Nth camera frame
YOLO_MODEL=yolo11s.pt          # yolo11n | yolo11s | yolo11m | yolo11l | yolo11x
YOLO_CONFIDENCE=0.4

WHISPER_MODEL=base             # tiny | base | small | medium
TTS_ENGINE=edge-tts            # edge-tts (free, Microsoft neural) | elevenlabs (premium API)
ELEVENLABS_API_KEY=            # Only needed if TTS_ENGINE=elevenlabs
ELEVENLABS_VOICE_ID=           # Optional — leave blank for default voice

MEMORY_DB_PATH=iris_memory.db  # SQLite file path (relative to repo root)
MEMORY_WINDOW_MINUTES=60
MEMORY_MIN_CONFIDENCE=0.6
MEMORY_STREAK_FRAMES=3
CONTEXT_WINDOW_TURNS=10

LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
PORT=8000
