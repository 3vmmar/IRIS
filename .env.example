# ── Anthropic / VLM ───────────────────────────────────────────────────────
# Anthropic API key — required at query time, not at import time.
# Example: sk-ant-api03...
ANTHROPIC_API_KEY=""

# Claude model to use: 'claude-haiku-4-5' (fast) or 'claude-sonnet-4-6' (detailed).
VLM_MODEL="claude-haiku-4-5"


# ── Camera & detection ────────────────────────────────────────────────────
# OpenCV device index for the camera (0 = default webcam).
CAMERA_INDEX=0

# Run YOLO26 inference every Nth frame to balance FPS vs. CPU load.
FRAME_SKIP=3

# YOLO model variant: yolo11n | yolo11s | yolo11m | yolo11l | yolo11x.
YOLO_MODEL="yolo11s.pt"

# Minimum YOLO detection confidence to pass a result downstream.
YOLO_CONFIDENCE=0.4


# ── Voice — speech-to-text ────────────────────────────────────────────────
# faster-whisper model size: tiny | base | small | medium.
WHISPER_MODEL="base"


# ── Voice — text-to-speech ────────────────────────────────────────────────
# TTS backend to use: 'edge-tts' (free, Microsoft neural) or 'elevenlabs' (API).
TTS_ENGINE="edge-tts"

# ElevenLabs API key — only required when tts_engine='elevenlabs'.
ELEVENLABS_API_KEY=""

# ElevenLabs voice ID to use for synthesis.
ELEVENLABS_VOICE_ID=""


# ── Visual memory ─────────────────────────────────────────────────────────
# Minimum detection confidence required to write a sighting to SQLite.
MEMORY_MIN_CONFIDENCE=0.6

# Consecutive frames a label must appear before its sighting is persisted.
MEMORY_STREAK_FRAMES=3

# Deduplication window: skip writes if same class+zone was logged within N minutes.
MEMORY_WINDOW_MINUTES=60

# File path for the SQLite visual memory database.
MEMORY_DB_PATH="iris_memory.db"


# ── Conversation context ──────────────────────────────────────────────────
# Number of (user, assistant) turn pairs to keep in the rolling context buffer.
CONTEXT_WINDOW_TURNS=10


# ── Server ────────────────────────────────────────────────────────────────
# Port for the Uvicorn / FastAPI server.
PORT=8000

# Uvicorn log level: debug | info | warning | error | critical.
LOG_LEVEL="info"
